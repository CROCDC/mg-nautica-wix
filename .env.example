# ─────────────────────────────────────────────────────────────────────────────
# MG Náutica storefront — environment variables
# Copy to .env.local (gitignored) and fill in. In production these live in Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# Wix OAuth public client id (visitor tokens for catalog/cart). NOT a secret —
# exposed to the browser, hence the NEXT_PUBLIC_ prefix.
# Get it in the Wix dashboard → Settings → Headless → create an OAuth app.
NEXT_PUBLIC_WIX_CLIENT_ID=

# Wix Stores site identifiers (from the live site; see plan §5).
WIX_SITE_ID=11bbc77b-4b38-4e03-b035-4fa58dfd5963
WIX_META_SITE_ID=90eb2d0e-cc22-422c-a42e-602fd3422f13

# Server-only Wix API key for build/admin reads (NEVER exposed to the browser).
# Optional for the public storefront; needed only for admin-scoped queries.
WIX_API_KEY=

# ─── Deploy (set as GitHub Actions secrets, not here) ────────────────────────
# VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID — used by .github/workflows/deploy.yml
